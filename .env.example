# ──────────────────────────────────────────────────────────────────
# selenium-ui-api — Environment Variables Template
# Copy this file to .env and fill in the real values.
# .env is git-ignored and MUST NOT be committed.
# ──────────────────────────────────────────────────────────────────

# ── Application URLs ───────────────────────────────────────────────
BASE_URL=https://mobalytics.gg
API_BASE_URL=https://api.mobalytics.gg

# ── Browser Settings ───────────────────────────────────────────────
# Supported values: chrome | firefox | edge
BROWSER=chrome

# Set to "false" to run tests with a visible browser window
HEADLESS=true

# ── Timeouts (milliseconds) ────────────────────────────────────────
DEFAULT_TIMEOUT=15000
NAVIGATION_TIMEOUT=30000
API_TIMEOUT=10000

# ── Retry & Parallelism ────────────────────────────────────────────
RETRY_COUNT=1
PARALLEL_THREADS=4

# ── Viewport ───────────────────────────────────────────────────────
VIEWPORT_WIDTH=1920
VIEWPORT_HEIGHT=1080

# ── Test Credentials (NEVER put real values in .env.example) ───────
USER_EMAIL=your-test-email@example.com
USER_PASSWORD=your-test-password
USER_USERNAME=your-test-username

# ── Allure Reporting ───────────────────────────────────────────────
ALLURE_RESULTS_DIR=target/allure-results
ALLURE_REPORT_DIR=target/allure-report

# ── Screenshot / Video Behaviour ───────────────────────────────────
SCREENSHOT_ON_FAILURE=true

