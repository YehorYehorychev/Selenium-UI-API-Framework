# ──────────────────────────────────────────────
# Java / Maven
# ──────────────────────────────────────────────
target/
*.class
*.jar
*.war
*.ear
*.nar

# Maven wrapper binary (generated, not committed)
.mvn/wrapper/maven-wrapper.jar

# Keep maven wrapper properties & scripts
!.mvn/wrapper/maven-wrapper.properties
!mvnw
!mvnw.cmd

# ──────────────────────────────────────────────
# IDE — IntelliJ IDEA
# ──────────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
out/

# ──────────────────────────────────────────────
# IDE — VS Code
# ──────────────────────────────────────────────
.vscode/
*.code-workspace

# ──────────────────────────────────────────────
# IDE — Eclipse / Spring
# ──────────────────────────────────────────────
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache
.apt_generated
bin/

# ──────────────────────────────────────────────
# IDE — NetBeans
# ──────────────────────────────────────────────
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/
build/

# ──────────────────────────────────────────────
# Test Reports & Allure
# ──────────────────────────────────────────────
allure-results/
allure-report/
cucumber-reports/
surefire-reports/
test-results/

# ──────────────────────────────────────────────
# Screenshots / Videos / Downloads
# ──────────────────────────────────────────────
screenshots/
videos/
downloads/
*.png
*.mp4
*.webm

# ──────────────────────────────────────────────
# Environment & Secrets — NEVER commit these
# ──────────────────────────────────────────────
.env
.env.local
.env.*.local
secrets.properties

# Keep the example template in VCS
!.env.example

# ──────────────────────────────────────────────
# OS artifacts
# ──────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ──────────────────────────────────────────────
# Logs
# ──────────────────────────────────────────────
*.log
logs/

# ──────────────────────────────────────────────
# WebDriverManager cache
# ──────────────────────────────────────────────
.wdm/
